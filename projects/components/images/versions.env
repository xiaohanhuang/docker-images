# ============================================================
# Central version pins for all ml-platform container images.
# Every Makefile target and Dockerfile ARG reads from here.
#
# To release a new set of images, bump IMAGE_TAG and rebuild.
# Run `make build-all` to build the full layer chain in order.
# ============================================================

# ── Upstream base versions ──────────────────────────────────
CUDA_VERSION   := 12.9.1
PYTHON_VERSION := 3.12

# ── Framework versions ──────────────────────────────────────
TORCH_VERSION      := 2.9.0
TORCHVISION_VERSION:= 0.24.0
TORCHAUDIO_VERSION := 2.9.0
FLYTEKIT_VERSION   := 1.14.3
RAY_VERSION        := 2.54.0

# ── Data workload versions ──────────────────────────────────
PANDAS_VERSION      := 2.2.2
PYARROW_VERSION     := 16.0.0
BOTO3_VERSION       := 1.34.84
S3FS_VERSION        := 2024.3.1
SKLEARN_VERSION     := 1.4.2
TIKTOKEN_VERSION    := 0.8.0
PYPDF_VERSION       := 5.1.0
BS4_VERSION         := 4.12.3
LXML_VERSION        := 5.3.0
NLTK_VERSION        := 3.9.1
REQUESTS_VERSION    := 2.31.0

# ── ML training workload versions ──────────────────────────
TRANSFORMERS_VERSION := 4.41.2
ACCELERATE_VERSION   := 0.30.1
PEFT_VERSION         := 0.11.1
DATASETS_VERSION     := 2.19.1
MLFLOW_VERSION       := 2.13.0
EVALUATE_VERSION     := 0.4.2
ROUGE_VERSION        := 0.1.2
SENTENCEPIECE_VERSION:= 0.2.0

# ── GenAI workload versions ─────────────────────────────────
VLLM_VERSION              := 0.5.0
LANGCHAIN_VERSION         := 0.2.5
LANGCHAIN_COMMUNITY_VERSION := 0.2.5
SENTENCE_TRANSFORMERS_VERSION := 3.0.1
OPENAI_VERSION            := 1.34.0
FAISS_VERSION             := 1.8.0
CHROMADB_VERSION          := 0.4.24
PSYCOPG2_VERSION          := 2.9.9
PGVECTOR_VERSION          := 0.3.5

# ── LLM training (Ray) workload versions ────────────────────
# (transformers/peft/accelerate/datasets reuse the same pins)
BITSANDBYTES_VERSION := 0.41.3
DEEPSPEED_VERSION    := 0.12.6
FLYTE_RAY_PLUGIN     := 1.14.3

# ── Image release tag ────────────────────────────────────────
# Bump this to cut a new release. The Makefile stamps every
# image tag as  <descriptive-prefix>-<IMAGE_TAG>  e.g.
#   base-gpu:cu12.9-torch2.9-1.0.0
#   data-cpu:1.0.0
IMAGE_TAG := 1.0.0

# ── ECR registry ─────────────────────────────────────────────
ECR_REGISTRY := 805673386114.dkr.ecr.us-west-2.amazonaws.com
ECR_REPO     := ml-platform
