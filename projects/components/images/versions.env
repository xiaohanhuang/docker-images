# ============================================================
# Central version pins for all ml-platform container images.
# Every Makefile target and Dockerfile ARG reads from here.
#
# To release a new set of images, bump IMAGE_TAG and rebuild.
# Run `make build-all` to build the full layer chain in order.
# ============================================================

# ── Upstream base versions ──────────────────────────────────
CUDA_VERSION   := 12.9.1
PYTHON_VERSION := 3.12

# ── Framework versions ──────────────────────────────────────
TORCH_VERSION      := 2.10.0
TORCHVISION_VERSION:= 0.25.0
TORCHAUDIO_VERSION := 2.10.0
FLYTEKIT_VERSION   := 1.16.14
RAY_VERSION        := 2.54.0

# ── Data workload versions ──────────────────────────────────
PANDAS_VERSION      := 2.2.2
PYARROW_VERSION     := 23.0.1
BOTO3_VERSION       := 1.42.61
S3FS_VERSION        := 2026.2.0
SKLEARN_VERSION     := 1.8.0
TIKTOKEN_VERSION    := 0.12.0
PYPDF_VERSION       := 6.7.5
BS4_VERSION         := 4.14.3
LXML_VERSION        := 6.0.2
NLTK_VERSION        := 3.9.3
REQUESTS_VERSION    := 2.32.5

# ── ML training workload versions ──────────────────────────
TRANSFORMERS_VERSION := 5.3.0
ACCELERATE_VERSION   := 1.13.0
PEFT_VERSION         := 0.18.1
DATASETS_VERSION     := 4.6.1
MLFLOW_VERSION       := 3.10.0
EVALUATE_VERSION     := 0.4.6
ROUGE_VERSION        := 0.1.2
SENTENCEPIECE_VERSION:= 0.2.1

# ── GenAI workload versions ─────────────────────────────────
VLLM_VERSION              := 0.16.0
LANGCHAIN_VERSION         := 1.2.10
LANGCHAIN_COMMUNITY_VERSION := 0.4.1
SENTENCE_TRANSFORMERS_VERSION := 5.2.3
OPENAI_VERSION            := 2.24.0
FAISS_VERSION             := 1.13.2
CHROMADB_VERSION          := 1.5.2
PSYCOPG2_VERSION          := 2.9.11
PGVECTOR_VERSION          := 0.4.2

# ── LLM training (Ray) workload versions ────────────────────
# (transformers/peft/accelerate/datasets reuse the same pins)
BITSANDBYTES_VERSION := 0.49.2
DEEPSPEED_VERSION    := 0.18.6
FLYTE_RAY_PLUGIN     := 1.16.14

# ── Image release tag ────────────────────────────────────────
# Bump this to cut a new release. The Makefile stamps every
# image tag as  <descriptive-prefix>-<IMAGE_TAG>  e.g.
#   base-gpu:cu12.9-torch2.9-1.0.0
#   data-cpu:1.0.0
IMAGE_TAG := 1.1.0

# ── ECR registry ─────────────────────────────────────────────
ECR_REGISTRY := 805673386114.dkr.ecr.us-west-2.amazonaws.com
ECR_REPO     := ml-platform
